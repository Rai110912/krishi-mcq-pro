{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.git/**",
      "**/.firebase/**",
      "**/.*",
      "**/node_modules/**",
      "qa_audit.py",
      "run_app.bat",
      "ip.json"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
